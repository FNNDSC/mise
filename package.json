{
  "name": "@fnndsc/mise",
  "version": "0.0.0",
  "private": true,
  "description": "MISE Integrates the Sandwich Ecosystem \u2014 monorepo for the ChELL stack (cumin, salsa, chili, chell), each published independently to npm.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @fnndsc/cumin && npm run build -w @fnndsc/calypso && npm run build -w @fnndsc/salsa && npm run build -w @fnndsc/chili && npm run build -w @fnndsc/chell",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:tests": "eslint --config eslint.tests.config.mjs \"packages/*/tests/**/*.{ts,js}\" \"packages/*/test/**/*.{ts,js}\"",
    "lint:seam": "eslint --config eslint.seam.config.mjs \"packages/*/src/**/*.ts\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@yao-pkg/pkg": "6.21.0",
    "esbuild": "0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jest": "^29.15.4",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "jest-config": {
      "glob": "^11.1.0"
    },
    "jest-runtime": {
      "glob": "^11.1.0"
    },
    "@jest/reporters": {
      "glob": "^11.1.0"
    },
    "test-exclude": {
      ".": "^7.0.1",
      "glob": "^11.1.0"
    }
  }
}
