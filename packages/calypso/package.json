{
  "name": "@fnndsc/calypso",
  "version": "0.3.7",
  "description": "The CALYPSO wire contract: typed protocol schemas and boundary validation for the ChRIS session daemon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FNNDSC/mise.git",
    "directory": "packages/calypso"
  },
  "homepage": "https://github.com/FNNDSC/mise/tree/main/packages/calypso#readme",
  "bugs": {
    "url": "https://github.com/FNNDSC/mise/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "calypso": "./dist/calypso.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -fr dist && tsc && chmod +x ./dist/calypso.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chris",
    "calypso",
    "wire-contract",
    "websocket",
    "fnndsc"
  ],
  "author": "Rudolph Pienaar",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@fnndsc/brasa": "^0.8.0",
    "@fnndsc/cumin": "^3.7.0",
    "chalk": "^4.1.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  }
}
