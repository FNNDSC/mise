{
  "name": "@fnndsc/chell",
  "version": "5.2.7",
  "description": "ChELL Executes Layered Logic - Interactive ChRIS REPL Shell",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FNNDSC/chell.git"
  },
  "homepage": "https://github.com/FNNDSC/chell#readme",
  "bugs": {
    "url": "https://github.com/FNNDSC/chell/issues"
  },
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "chell": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x ./dist/index.js",
    "exemplars:build": "tsc -p exemplars/ts",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --forceExit --coverage",
    "bundle": "node scripts/bundle.mjs",
    "pkg:binaries": "pkg build/chell.cjs -t node22-linux-x64 -o build/bin/chell-linux-x64 && pkg build/chell.cjs -t node22-linux-arm64 -o build/bin/chell-linux-arm64 && pkg build/chell.cjs -t node22-macos-x64 -o build/bin/chell-macos-x64 && pkg build/chell.cjs -t node22-macos-arm64 -o build/bin/chell-macos-arm64",
    "binaries": "npm run bundle && npm run pkg:binaries"
  },
  "keywords": [
    "chris",
    "fnndsc",
    "cli",
    "repl",
    "shell"
  ],
  "author": "FNNDSC <dev@babyMRI.org>",
  "license": "MIT",
  "dependencies": {
    "@fnndsc/brasa": "^0.9.5",
    "@fnndsc/chili": "^3.6.1",
    "@fnndsc/cumin": "^3.8.3",
    "@fnndsc/salsa": "^3.5.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "figlet": "^1.7.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "minimatch": "^10.1.1",
    "ws": "^8.21.0",
    "@fnndsc/calypso": "^0.4.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.5.2"
  },
  "overrides": {
    "glob": "^10.0.0",
    "inflight": "npm:@aashutoshrathi/word-wrap@^1.2.6",
    "node-domexception": "npm:undici-types@^6.19.8"
  }
}
