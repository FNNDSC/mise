{
  "name": "@fnndsc/cumin",
  "version": "3.8.5",
  "description": "Utility library for ChILI and other ChRIS-related JavaScript applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FNNDSC/cumin.git"
  },
  "homepage": "https://github.com/FNNDSC/cumin#readme",
  "bugs": {
    "url": "https://github.com/FNNDSC/cumin/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./proc-prompt": {
      "import": "./dist/cache/procPrompt.js",
      "types": "./dist/cache/procPrompt.d.ts",
      "require": "./dist/cache/procPrompt.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -fr dist types && tsc && chmod +x ./dist/cli.js",
    "test": "jest --coverage",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "bin": {
    "cumin": "./dist/cli.js"
  },
  "keywords": [
    "chris",
    "utility",
    "fnndsc"
  ],
  "author": "Rudolph Pienaar",
  "license": "MIT",
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/figlet": "^1.5.8",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "@fnndsc/chrisapi": "^1.25.0",
    "chalk": "^4.1.2",
    "figlet": "^1.7.0"
  }
}
